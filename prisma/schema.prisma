// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum UserType {
    developer
    provider
    standard
}

model User {
    id   String   @id @default(cuid())
    type UserType @default(standard)

    // Auth
    email             String    @unique @db.VarChar(128)
    phone             String    @db.VarChar(32)
    emailVerified     DateTime? @map("email_verified")
    authEmailVerified Boolean   @default(false) @map("auth_email_verified")
    password          String    @db.VarChar(64)
    authName          String    @default("") @map("auth_name") @db.VarChar(128)

    // Profile
    firstName   String   @map("first_name") @db.VarChar(64)
    lastName    String   @map("last_name") @db.VarChar(64)
    displayName String?  @map("display_name") @db.VarChar(128)
    dateOfBirth DateTime @map("date_of_birth") @db.Date
    image       String?  @db.Text
    timezone    String?  @db.VarChar(32)
    locale      String?  @db.VarChar(16)

    // Terms & Conditions
    termsAccepted        DateTime? @map("terms_accepted")
    privacyAccepted      DateTime? @map("privacy_accepted")
    cookiesAccepted      DateTime? @map("cookies_accepted")
    textMessagesAccepted DateTime? @map("text_messages_accepted")

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    sessions       Session[]
    accounts       Account[]
    assessments    Assessment[]
    Step           Step[]
    expoPushTokens ExpoPushToken[]
    chatSessions   ChatSession[]

    @@map("users")
}

enum ChatMessageSender {
    user
    ai
    system
}

model ChatSession {
    id            String        @id @default(uuid()) @db.Uuid
    customerEmail String        @map("customer_email") @db.VarChar(128)
    createdAt     DateTime      @default(now()) @map("created_at")

    // Relations
    customer User          @relation(fields: [customerEmail], references: [email], onDelete: Cascade)
    messages ChatMessage[]

    @@index([customerEmail])
    @@map("chat_sessions")
}

model ChatMessage {
    id        String            @id @default(uuid()) @db.Uuid
    sessionId String            @map("session_id") @db.Uuid
    sender    ChatMessageSender
    content   String            @db.Text
    metadata  Json?
    createdAt DateTime          @default(now()) @map("created_at")

    // Relations
    session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@index([sessionId, createdAt])
    @@map("chat_messages")
}

model Session {
    id     String @id @default(cuid())
    userId String @map("user_id") @db.VarChar(32)

    // Better Auth
    token     String    @unique @default(cuid()) @db.VarChar(255)
    expiresAt DateTime  @default(now()) @map("expires_at")
    ipAddress String?   @map("ip_address") @db.VarChar(255)
    userAgent String?   @map("user_agent") @db.VarChar(512)

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    stediSessionLink StediSessionLink?

    @@map("sessions")
}

model Account {
    id                    String    @id @default(cuid())
    accountId             String    @map("account_id") @db.VarChar(255)
    providerId            String    @map("provider_id") @db.VarChar(255)
    userId                String    @map("user_id") @db.VarChar(32)
    accessToken           String?   @map("access_token") @db.Text
    refreshToken          String?   @map("refresh_token") @db.Text
    idToken               String?   @map("id_token") @db.Text
    accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
    refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
    scope                 String?   @db.Text
    password              String?   @db.Text
    createdAt             DateTime  @default(now()) @map("created_at")
    updatedAt             DateTime  @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([providerId, accountId])
    @@index([userId])
    @@map("accounts")
}

model Verification {
    id         String   @id @default(cuid())
    identifier String   @db.VarChar(255)
    value      String   @db.Text
    expiresAt  DateTime @map("expires_at")
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @updatedAt @map("updated_at")

    @@index([identifier])
    @@map("verifications")
}

model StediSessionLink {
    id         String   @id @default(cuid())
    sessionId  String   @unique @map("session_id")
    username   String   @db.VarChar(128)
    stediToken String   @map("stedi_token") @db.Text
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @updatedAt @map("updated_at")

    session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@map("stedi_session_links")
}

model Device {
    id    String @id @default(cuid())
    name  String @db.VarChar(64)
    token String @unique @db.VarChar(64)

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    assessments Assessment[]
    steps       Step[]

    @@map("devices")
}

model Assessment {
    id       String    @id @default(cuid())
    userId   String    @map("user_id") @db.VarChar(32)
    deviceId String    @map("device_id") @db.VarChar(32)
    started  DateTime? @default(now())
    ended    DateTime?

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
    steps  Step[]

    @@map("assessments")
}

model Step {
    id           String  @id @default(cuid())
    deviceId     String  @map("device_id") @db.VarChar(32)
    assessmentId String? @map("assessment_id") @db.VarChar(32)
    userId       String? @map("user_id") @db.VarChar(32)

    points Json

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    device     Device?     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
    assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
    user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("steps")
}

enum ClinicianAccessStatus {
    PENDING
    APPROVED
    REJECTED
}

model ClinicianAccessRequest {
    id           String                 @id @default(cuid())
    clinicianId  String?                @map("clinician_id") @db.VarChar(128)
    customerEmail String                @map("customer_email") @db.VarChar(128)
    status       ClinicianAccessStatus  @default(PENDING)
    accessToken  String?                @map("access_token") @db.VarChar(128)
    tokenExpiresAt DateTime?            @map("token_expires_at")
    createdAt    DateTime               @default(now()) @map("created_at")
    expiresAt    DateTime               @map("expires_at")

    @@map("clinician_access_requests")
}

model CustomerConsent {
    id           String   @id @default(cuid())
    customerEmail String  @unique @map("customer_email") @db.VarChar(128)
    agreedToTerms Boolean @map("agreed_to_terms")
    createdAt    DateTime @default(now()) @map("created_at")
    updatedAt    DateTime @updatedAt @map("updated_at")

    @@map("customer_consents")
}

model ExpoPushToken {
    id     String @id @default(cuid())
    userId String @map("user_id") @db.VarChar(32)

    // Token
    token      String    @unique @db.VarChar(255)
    deviceName String?   @map("device_name") @db.VarChar(64)
    platform   String?   @db.VarChar(16)
    isActive   Boolean   @default(true) @map("is_active")
    lastUsedAt DateTime? @map("last_used_at")

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("expo_push_tokens")
}
