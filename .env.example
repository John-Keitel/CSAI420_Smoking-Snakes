# App
APP_ENV="local"
APP_LOG_LEVEL="debug"
STEDI_API_BASE_URL="https://dev.stedi.me"
STEDI_PROXY_TIMEOUT_MS="8000"
API_URL="http://127.0.0.1:3000"
VOICE_LLM_ENABLED="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Docker host bindings
APP_BIND_ADDRESS="127.0.0.1"
APP_PORT=3000
SERVICE_BIND_ADDRESS="127.0.0.1"

# Database
DATABASE_URL="postgresql://stedi:stedipassword@localhost:5432/postgres?schema=public"
DATABASE_DIRECT_URL="postgresql://stedi:stedipassword@localhost:5432/postgres?schema=public"
DOCKER_DATABASE_URL="postgresql://stedi:stedipassword@postgres:5432/postgres?schema=public"
DOCKER_DATABASE_DIRECT_URL="postgresql://stedi:stedipassword@postgres:5432/postgres?schema=public"
DATABASE_DEBUG=false
POSTGRES_USER=stedi
POSTGRES_PASSWORD=stedipassword
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Authentication
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_DEBUG=false
AUTH_TRUST_HOST=true

# Mail
MAILER_FROM_EMAIL=team@stedi.com
MAILER_SMTP_HOST=localhost
MAILER_SMTP_PORT=1025
DOCKER_MAILER_SMTP_HOST=mailpit
DOCKER_MAILER_SMTP_PORT=1025
MAILER_SMTP_USERNAME=user
MAILER_SMTP_PASSWORD=secret
MAILER_SMTP_ENCRYPTION=tls

# AI
OPENAI_API_KEY=
